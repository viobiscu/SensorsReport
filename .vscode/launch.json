{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "coreclr",
      "request": "launch",
      "name": "Debug MqttToOrion",
      "program": "${workspaceFolder}/mqtttoorion/bin/Debug/net9.0/mqtttoorion.dll",
      "args": [],
      "cwd": "${workspaceFolder}/mqtttoorion",
      "stopAtEntry": false,
      "console": "internalConsole",
      "preLaunchTask": "build-mqtttoorion"
    },
    {
      "type": "coreclr",
      "request": "launch",
      "name": "Debug SensorsReportAudit.API",
      "program": "${workspaceFolder}/SensorsReportAudit.API/bin/Debug/net8.0/SensorsReportAudit.API.dll",
      "args": [],
      "cwd": "${workspaceFolder}/SensorsReportAudit.API",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      },
      "preLaunchTask": "build-sensorsreportaudit-api",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "SR_AUDIT_QUANTUMLEAP_HOST": "quantum.sensorsreport.net",
        "SR_AUDIT_QUANTUMLEAP_PORT": "8668",
        "SR_AUDIT_KEYCLOAK_URL": "keycloak.sensorsreport.net",
        "SR_AUDIT_KEYCLOAK_PORT": "30100",
        "SR_AUDIT_KEYCLOAK_REALM": "sr"
      }
    }
  ],
  "inputs": [
    {
      "id": "targetFramework",
      "type": "pickString",
      "description": "Select the target framework for MqttToOrion",
      "options": [
        "net9.0"
      ]
    }
  ]
}